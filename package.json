{
  "name": "@justinfan/agent-workflow",
  "version": "4.0.0",
  "description": "AI 编码工具通用工作流系统 - Skills 架构支持 9 个 AI 工具 (Claude Code, Cursor, Codex, Gemini 等)",
  "bin": {
    "agent-workflow": "bin/agent-workflow.js"
  },
  "main": "lib/index.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "node scripts/validate.js",
    "sync": "node bin/agent-workflow.js sync",
    "link": "node bin/agent-workflow.js link",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "templates/",
    "!templates/**/__pycache__/",
    "!templates/**/*.py[cod]",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "picocolors": "^1.1.1",
    "semver": "^7.6.3"
  },
  "keywords": [
    "claude",
    "workflow",
    "skills",
    "cli",
    "automation",
    "codex",
    "gemini",
    "cursor",
    "multi-agent",
    "multi-model",
    "ai",
    "collaboration",
    "code-review",
    "testing",
    "figma"
  ],
  "author": "PIC Team",
  "license": "MIT"
}
