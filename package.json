{
  "name": "@pic/claude-workflow",
  "version": "3.3.5",
  "description": "AI 编码工具通用工作流系统 - Skills 架构支持 10+ AI 工具 (Claude Code, Cursor, Codex, Gemini 等)",
  "bin": {
    "claude-workflow": "./bin/claude-workflow.js"
  },
  "main": "lib/index.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "node scripts/validate.js",
    "sync": "node bin/claude-workflow.js sync",
