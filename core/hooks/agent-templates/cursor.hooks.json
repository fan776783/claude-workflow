{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node {{HOOKS_DIR}}/session-start.js",
        "timeout": 30
      }
    ],
    "preToolUse": [
      {
        "command": "node {{HOOKS_DIR}}/pre-execute-inject.js",
        "matcher": "Task|Subagent",
        "timeout": 30
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node {{HOOKS_DIR}}/inject-shell-session-context.js",
        "timeout": 5
      }
    ]
  }
}
