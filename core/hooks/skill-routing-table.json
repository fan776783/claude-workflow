    "prototype",
    "quick-plan",
    "research",
    "scan",
    "spec-bootstrap",
    "spec-review",
    "spec-update",
    "system-design",
    "tdd",
    "ux-elaboration",
    "workflow-archive",
    "workflow-delta",
    "workflow-execute",
    "workflow-plan",
    "workflow-review",
    "workflow-spec",
    "workflow-status",
    "write-a-skill",
    "zoom-out"
  ]
}
