# ── 基础 ────────────────────────────────────────────────
SMOKE_HOST=api-dev.example.com        # HTTP Host + HTTPS SNI
SMOKE_PROTOCOL=https                  # https / http
# SMOKE_PORT=443
# SMOKE_RESOLVE_IP=10.13.0.36         # 内网测试环境 TCP 直连;公网留空
# SMOKE_TLS_REJECT_UNAUTHORIZED=0     # 自签证书绕过
SMOKE_TIMEOUT_MS=15000
SMOKE_COOKIE=                         # 从浏览器 devtools 复制完整 Cookie

# ── 运行时日志 ──────────────────────────────────────────
SMOKE_VERBOSE=0                       # 1 → 控制台 + trace.log 实时打印
# SMOKE_LOG_FILE=logs/debug.ndjson    # 单跑时指定 NDJSON 日志路径;run-all 自动挂载
SMOKE_RETRY=0                         # 1 → 对 5xx / SMOKE_RETRY_STATUSES 静默重试一次
# SMOKE_RETRY_STATUSES=5xx,744        # 逗号分隔;5xx 表示 500-599;数字表示业务 code

# ── 拦截器 header(SKILL.md Step 3 产出规则表按模板填) ──
# SMOKE_PROD_ID=
# SMOKE_PROD_VER=
# SMOKE_MODEL_VER=
# SMOKE_LANG=zh-cn
# SMOKE_CLIENT_SN=                    # 留空 → 自动从 cookie 抽(如 driveweb_identity)
# SMOKE_SPACE_ID=0

# ── 业务上下文(Step 4 参数语义探测产出) ────────────────
# SMOKE_TEAM_ID=
