{
  "name": "@justinfan/agent-workflow",
  "version": "6.6.13",
  "description": "AI 编码工具通用工作流系统 - Skills 架构，Claude Code 通过 Plugin 机制分发，其他 8 个工具（Cursor, Codex, Gemini 等）通过 installer 分发",
  "bin": {
    "agent-workflow": "bin/agent-workflow.js"
  },
  "main": "lib/index.js",
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "node scripts/validate.js && npm run test:codex-bridge && npm run test:lib && npm run test:workflow && npm run test:shared",
    "test:codex-bridge": "node --test core/skills/collaborating-with-codex/scripts/lib/__tests__/*.test.mjs",
    "test:lib": "node --test lib/__tests__/*.test.mjs",
    "test:workflow": "node --test core/utils/workflow/__tests__/*.test.mjs",
    "test:shared": "node --test core/skills/_shared/*.test.mjs",
    "test": "npm run test:codex-bridge && npm run test:lib && npm run test:workflow && npm run test:shared",
    "sync": "node bin/agent-workflow.js sync",
    "link": "node bin/agent-workflow.js link",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "publish:public": "./scripts/publish-public.sh",
    "publish:public:dry": "./scripts/publish-public.sh --dry-run"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "core/",
    ".claude-plugin/",
    "!core/**/__pycache__/",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6",
    "picocolors": "^1.1.1",
    "semver": "^7.6.3"
  },
  "keywords": [
    "claude",
    "workflow",
    "skills",
    "cli",
    "automation",
    "codex",
    "gemini",
    "cursor",
    "multi-agent",
    "multi-model",
    "ai",
    "collaboration",
    "code-review",
    "testing",
    "figma"
  ],
  "author": "PIC Team",
  "license": "MIT"
}
