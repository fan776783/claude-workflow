    "picocolors": "^1.1.1",
    "semver": "^7.6.3"
  },
  "keywords": [
    "claude",
    "workflow",
    "skills",
    "cli",
    "automation",
    "codex",
    "gemini",
    "cursor",
    "multi-agent",
    "multi-model",
