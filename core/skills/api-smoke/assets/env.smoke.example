# Base target
# HTTP Host and HTTPS SNI.
SMOKE_HOST=api-dev.example.com
# https / http
SMOKE_PROTOCOL=https
# Optional port. Defaults to 443 for https and 80 for http.
# SMOKE_PORT=443
# TCP direct IP for internal environments. Leave blank for normal DNS.
# SMOKE_RESOLVE_IP=10.13.0.36
# Set to 0 for self-signed certificates.
# SMOKE_TLS_REJECT_UNAUTHORIZED=0
SMOKE_TIMEOUT_MS=15000
# Paste the full browser Cookie header value.
SMOKE_COOKIE=

# Runtime logging
# 1 prints requests to console and trace.log.
SMOKE_VERBOSE=0
# Single-file runs can set an NDJSON path. run-all sets this automatically.
# SMOKE_LOG_FILE=logs/debug.ndjson
# 1 retries matching statuses once.
SMOKE_RETRY=0
# Comma separated. 5xx means HTTP 500-599; numbers also match business code.
# SMOKE_RETRY_STATUSES=5xx,744

# Client/interceptor headers
# Use SMOKE_HEADER_<NAME>. Underscores become hyphens and segments are title-cased.
# Plain values are logged verbatim into trace.log / logs/*.ndjson / report.md.
# Cookie and Authorization are auto-redacted. For any other secret header,
# prefix the value with @secret: (or @cookie:<key> to pull it from the cookie)
# so it is masked in all artifacts.
# SMOKE_HEADER_X_SPACE_ID=123
# SMOKE_HEADER_X_CLIENT_SN=@cookie:client_sn
# SMOKE_HEADER_X_API_KEY=@secret:replace-me
# SMOKE_HEADER_AUTHORIZATION=Bearer replace-me
# Do not set SMOKE_HEADER_HOST or SMOKE_HEADER_COOKIE.

# Business context discovered from semantic probes
# SMOKE_TEAM_ID=
